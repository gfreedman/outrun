{
  "name": "outrun",
  "version": "1.0.0",
  "description": "Browser-based OutRun tribute — pseudo-3D road renderer, physics, traffic, and sprites in vanilla TypeScript.",
  "license": "MIT",
  "scripts": {
    "prebuild": "tsx scripts/generate-road.ts",
    "predev":   "tsx scripts/generate-road.ts",
    "dev": "esbuild src/main.ts --bundle --outfile=dist/script.js --sourcemap --watch",
    "build": "esbuild src/main.ts --bundle --outfile=dist/script.js --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
